{
  "name": "@contrailspec/core",
  "version": "0.0.0",
  "description": "Contrail core library — parse, validate, resolve trajectories, serialize",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --if-present",
    "test:watch": "vitest --if-present",
    "lint": "eslint src --ext .ts --if-present",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "contrail",
    "ai-memory",
    "temporal",
    "claim",
    "trajectory"
  ],
  "license": "Apache-2.0",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "ajv": "^8.12.0"
  }
}